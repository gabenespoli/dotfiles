{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "d_bg": "#0f171b",
    "d_bg2": "#141f1f",
    "d_fg": "#adad9b",
    "d_bg_light": "#2b302b",
    "d_red": "#e52e1a",
    "d_green": "#1c9c40",
    "d_brown": "#a57230",
    "d_blue": "#0094cf",
    "d_purple": "#8b72da",
    "d_cyan": "#1dae87",
    "d_fg_light": "#cdc08b",
    "d_fg_com": "#6a6a5b",
    "d_orange": "#ea901a",
    "d_green_light": "#22bd4e",
    "d_yellow": "#c89b13",
    "d_blue_light": "#00a3cc",
    "d_pink": "#df7376",
    "d_cyan_light": "#4abe65",
    "d_fg_bright": "#e5e5d2",

    "l_bg": "#e5e5d2",
    "l_fg": "#2d2d24",
    "l_bg_light": "#d0d0be",
    "l_red": "#e52e1a",
    "l_green": "#1c8c38",
    "l_brown": "#8f6228",
    "l_blue": "#0085ba",
    "l_purple": "#7560c4",
    "l_cyan": "#18956f",
    "l_fg_light": "#252a25",
    "l_fg_com": "#b0b09e",
    "l_orange": "#d07815",
    "l_green_light": "#1a9a3e",
    "l_yellow": "#a58010",
    "l_blue_light": "#008cb0",
    "l_pink": "#c85a5d",
    "l_cyan_light": "#389048",
    "l_fg_bright": "#0f171b"
