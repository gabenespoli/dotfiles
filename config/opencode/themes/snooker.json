      "dark": "d_fg",
      "light": "l_fg"
    },
    "markdownListEnumeration": {
      "dark": "d_fg_light",
      "light": "l_fg_light"
    },
    "markdownImage": {
      "dark": "d_orange",
      "light": "l_orange"
    },
    "markdownImageText": {
      "dark": "d_fg_light",
      "light": "l_fg_light"
    },
    "markdownCodeBlock": {
      "dark": "d_fg",
      "light": "l_fg"
    },
    "syntaxComment": {
      "dark": "d_fg_com",
      "light": "l_fg_com"
    },
    "syntaxKeyword": {
      "dark": "d_green",
      "light": "l_green"
    },
    "syntaxFunction": {
      "dark": "d_blue",
      "light": "l_blue"
    },
    "syntaxVariable": {
      "dark": "d_fg_light",
      "light": "l_fg_light"
    },
    "syntaxString": {
      "dark": "d_cyan",
      "light": "l_cyan"
    },
    "syntaxNumber": {
      "dark": "d_cyan",
      "light": "l_cyan"
    },
    "syntaxType": {
      "dark": "d_yellow",
      "light": "l_yellow"
    },
    "syntaxOperator": {
      "dark": "d_fg",
      "light": "l_fg"
    },
    "syntaxPunctuation": {
      "dark": "d_fg",
      "light": "l_fg"
    }
