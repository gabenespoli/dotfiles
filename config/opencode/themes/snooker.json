    "diffContext": {
      "dark": "d_brown",
      "light": "l_brown"
    },
    "diffHunkHeader": {
      "dark": "d_purple",
      "light": "l_purple"
    },
    "diffHighlightAdded": {
      "dark": "d_green_light",
