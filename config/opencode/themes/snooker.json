    "markdownLink": {
      "dark": "d_brown",
      "light": "l_brown"
    },
    "markdownLinkText": {
      "dark": "d_blue",
      "light": "l_blue"
    },
    "markdownCode": {
      "dark": "d_cyan_light",
      "light": "l_cyan_light"
    },
    "markdownBlockQuote": {
      "dark": "d_brown",
      "light": "l_brown"
    },
    "markdownEmph": {
      "dark": "d_blue_light",
      "light": "l_blue_light"
    },
    "markdownStrong": {
      "dark": "d_fg_light",
      "light": "l_fg_light"
