  "theme": {
    "primary": {
      "dark": "d_fg_com",
      "light": "l_fg_com"
    },
    "secondary": {
      "dark": "d_pink",
      "light": "l_pink"
    },
    "accent": {
      "dark": "d_purple",
      "light": "l_purple"
    },
    "error": {
      "dark": "d_red",
      "light": "l_red"
    },
    "warning": {
      "dark": "d_orange",
      "light": "l_orange"
    },
    "success": {
      "dark": "d_green_light",
      "light": "l_green_light"
    },
    "info": {
      "dark": "d_purple",
      "light": "l_purple"
    },
    "text": {
      "dark": "d_fg",
      "light": "l_fg"
    },
    "textMuted": {
      "dark": "d_fg",
      "light": "l_fg_com"
    },
    "background": {
      "dark": "d_bg",
      "light": "l_bg"
    },
