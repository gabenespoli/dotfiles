# system  {{{1
auto-update = check
clipboard-read = allow
clipboard-write = allow
macos-titlebar-style = hidden
macos-icon = custom-style
macos-icon-frame = beige
macos-icon-ghost-color = ffffff
macos-icon-screen-color = 000000

# terminal  {{{1
resize-overlay = never
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor
font-family = MonoLisaWSLiga Nerd Font
font-size = 14
font-thicken = true
adjust-cell-width = -1

# keybindings  {{{1
keybind = cmd+zero=esc:0
keybind = cmd+one=esc:1
keybind = cmd+two=esc:2
keybind = cmd+three=esc:3
keybind = cmd+four=esc:4
keybind = cmd+five=esc:5
keybind = cmd+six=esc:6
keybind = cmd+seven=esc:7
keybind = cmd+eight=esc:8
keybind = cmd+nine=esc:9
keybind = cmd+b=esc:b
keybind = cmd+d=esc:d
keybind = cmd+f=esc:f
keybind = cmd+h=esc:h
keybind = cmd+j=esc:j
keybind = cmd+k=esc:k
keybind = cmd+l=esc:l
keybind = cmd+o=esc:o
keybind = cmd+shift+o=esc:O
keybind = cmd+s=esc:s
keybind = cmd+t=esc:t
keybind = "cmd+left_bracket=esc:["
keybind = "cmd+right_bracket=esc:]"
keybind = "cmd+shift+left_bracket=esc:{"
keybind = "cmd+shift+right_bracket=esc:}"

# colors  {{{1
theme = dark:snooker-dark,light:snooker-light
